CREATE TABLE IF NOT EXISTS users (
  id INT AUTO_INCREMENT PRIMARY KEY,

  username VARCHAR(100) NOT NULL UNIQUE,
  password VARCHAR(255) NOT NULL,
  profile_picture LONGBLOB,

  first_name VARCHAR(100) NOT NULL,
  middle_name VARCHAR(50),
  last_name VARCHAR(50) NOT NULL,
  extension_name VARCHAR(10) DEFAULT NULL,
  user_id VARCHAR(50) NOT NULL UNIQUE,
  birth_date DATE NOT NULL,
  gender ENUM('Male', 'Female', 'Other') NOT NULL,
  address VARCHAR(255) NOT NULL,
  contact_number VARCHAR(20) NOT NULL,
  email_address VARCHAR(100) NOT NULL UNIQUE,

  email_verified_at TIMESTAMP NULL,
  email_verification_token VARCHAR(255),
  email_verification_expires TIMESTAMP NULL,

  password_reset_token VARCHAR(255),
  password_reset_expires TIMESTAMP NULL,

  role ENUM('student','supervisor','admin') NOT NULL,
  deleted_at TIMESTAMP NULL DEFAULT NULL,
  
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS offices (
  id INT AUTO_INCREMENT PRIMARY KEY,

  name VARCHAR(150) NOT NULL, 
  address VARCHAR(255),
  contact_email VARCHAR(150), 
  contact_phone VARCHAR(20),  
  deleted_at TIMESTAMP NULL DEFAULT NULL,

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS student_details (
  id INT AUTO_INCREMENT PRIMARY KEY,

  student_id INT NOT NULL UNIQUE,
  year INT(1) NOT NULL,
  program VARCHAR(100) NOT NULL,
  major VARCHAR(100) NOT NULL,
  section VARCHAR(50) NOT NULL,

  FOREIGN KEY (student_id) REFERENCES users(id) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS supervisor_details (
  id INT AUTO_INCREMENT PRIMARY KEY,

  supervisor_id INT NOT NULL UNIQUE,
  office_id INT NOT NULL,
  position VARCHAR(255) NOT NULL,

  FOREIGN KEY (supervisor_id) REFERENCES users(id) ON DELETE CASCADE,
  FOREIGN KEY (office_id) REFERENCES offices(id) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS student_ojt (
  id INT AUTO_INCREMENT PRIMARY KEY,

  student_id INT NOT NULL,
  supervisor_id INT DEFAULT NULL,
  office_id INT,

  academic_year VARCHAR(20) NOT NULL,
  term ENUM('1st', '2nd', 'Summer') NOT NULL,
  required_hours DECIMAL(5,2) NOT NULL,
  rendered_hours DECIMAL(5,2) DEFAULT 0,
  status ENUM('pending', 'ongoing', 'completed', 'dropped') DEFAULT 'pending',
  start_date DATE NOT NULL,
  end_date DATE NOT NULL,
  supervisor_notes TEXT NULL,
  deleted_at TIMESTAMP NULL DEFAULT NULL,

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,

  FOREIGN KEY (student_id) REFERENCES users(id) ON DELETE CASCADE,
  FOREIGN KEY (supervisor_id) REFERENCES users(id) ON DELETE SET NULL,
  FOREIGN KEY (office_id) REFERENCES offices(id) ON DELETE CASCADE,

  INDEX idx_student (student_id),
  INDEX idx_supervisor (supervisor_id),
  INDEX idx_office (office_id),
  INDEX idx_academic_year_term (academic_year, term),
  INDEX idx_status (status),
  INDEX idx_student_year_status (student_id, academic_year, status)
);

CREATE TABLE IF NOT EXISTS attendance (
  id INT AUTO_INCREMENT PRIMARY KEY,

  student_id INT NOT NULL UNIQUE,
  ojt_id INT NOT NULL UNIQUE,

  date DATE NOT NULL,
  morning_in TIME,
  morning_out TIME,
  afternoon_in TIME,
  afternoon_out TIME,

  FOREIGN KEY (student_id) REFERENCES users(id) ON DELETE CASCADE,
  FOREIGN KEY (ojt_id) REFERENCES student_ojt(id) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS reports (
  id INT PRIMARY KEY AUTO_INCREMENT,

  student_id INT NOT NULL,
  ojt_id INT NOT NULL,

  type ENUM('daily', 'weekly', 'monthly', 'midterm', 'final', 'incident'),
  report_date DATE NOT NULL,          
  title VARCHAR(255) NULL,
  content TEXT NOT NULL,            
  attachments JSON NULL,  

  status ENUM('pending', 'approved', 'rejected') DEFAULT 'pending',
  reviewed_by INT NULL,
  reviewed_at TIMESTAMP NULL,
  feedback TEXT NULL,
  deleted_at TIMESTAMP NULL DEFAULT NULL,

  FOREIGN KEY (student_id) REFERENCES users(id) ON DELETE CASCADE,
  FOREIGN KEY (ojt_id) REFERENCES student_ojt(id) ON DELETE CASCADE,

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS activity (
  id INT AUTO_INCREMENT PRIMARY KEY,

  database_id INT NOT NULL,
  ojt_id INT NULL,

  action VARCHAR(50) NOT NULL,
  target_type VARCHAR(50) NULL,
  description TEXT NULL,

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  FOREIGN KEY (database_id) REFERENCES users(id) ON DELETE CASCADE,
  FOREIGN KEY (ojt_id) REFERENCES student_ojt(id) ON DELETE CASCADE,

  INDEX idx_database_id (database_id),
  INDEX idx_ojt_id (ojt_id),
  INDEX idx_created_at (created_at),
  INDEX idx_action (action)
);

CREATE TABLE IF NOT EXISTS settings (
  id INT PRIMARY KEY AUTO_INCREMENT,
  setting_key VARCHAR(100) NOT NULL UNIQUE,
  setting_value VARCHAR(255) NOT NULL,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

